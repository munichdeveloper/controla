# Docker / Compose template for Controla
# Copy this file to .env and adjust the values for your environment.

# PostgreSQL
POSTGRES_DB=controla
POSTGRES_USER=controla_user
POSTGRES_PASSWORD=controla_secure_password
POSTGRES_PORT=5432
POSTGRES_DEV_PORT=5433

# Spring Boot backend
SERVER_PORT=8081
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/controla
SPRING_DATASOURCE_USERNAME=controla_user
SPRING_DATASOURCE_PASSWORD=controla_secure_password
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CONTROLA_SECURITY_MASTER_KEY=change-me-to-a-very-secure-random-string-32-chars
JWT_SECRET=controla-secret-key-min-32-chars-required-for-security
JWT_EXPIRATION=86400000

# Agency Core integration
CORE_BASE_URL=http://host.docker.internal:8081
CORE_API_TOKEN=dev-apikey-123
CORE_TENANT_ID=123e4567-e89b-12d3-a456-426614174000

# Frontend / password reset URLs
BACKEND_URL=http://localhost:8081/api
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8081/api
FRONTEND_URL=http://localhost:3000

# Optional mail / password reset settings
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@controla.local
MAIL_FROM_NAME=controla
PASSWORD_RESET_TOKEN_VALIDITY_HOURS=24
EMAIL_LOCALE=de_DE
EMAIL_BRANDING=controla

